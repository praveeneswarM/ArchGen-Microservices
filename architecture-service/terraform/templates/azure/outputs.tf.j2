output "resource_group_name" {
  value       = azurerm_resource_group.rg.name
  description = "The name of the scoped resource group"
}

{% for node in nodes %}
{% set safe_id = node.id | sanitize_id %}
{% if node.type == 'FrontendNode' %}
output "frontend_endpoint_{{ safe_id }}" {
  value       = azurerm_static_web_app.spa_frontend_{{ safe_id }}.default_host_name
  description = "Public static hosting hostname of the frontend SPA application"
}
{% elif node.type == 'BackendNode' %}
output "backend_api_url_{{ safe_id }}" {
  value       = azurerm_container_app.api_backend_{{ safe_id }}.ingress[0].fqdn
  description = "Fully Qualified Domain Name of the containerized core backend API service"
}
{% elif node.type == 'DatabaseNode' %}
{% if 'Cosmos' in node.data.label or 'nosql' in node.id %}
output "database_endpoint_{{ safe_id }}" {
  value       = azurerm_cosmosdb_account.cosmos_db_{{ safe_id }}.endpoint
  description = "The connection endpoint of the Cosmos DB NoSQL account"
}
{% else %}
output "database_fqdn_{{ safe_id }}" {
  value       = azurerm_postgresql_flexible_server.postgres_db_{{ safe_id }}.fqdn
  description = "The fully qualified server name of the flexible PostgreSQL instances"
}
{% endif %}
{% elif node.type == 'CacheNode' %}
output "redis_hostname_{{ safe_id }}" {
  value       = azurerm_redis_cache.redis_cache_{{ safe_id }}.hostname
  description = "Host connection string endpoint of the Redis caching cluster"
}
{% endif %}
{% endfor %}
