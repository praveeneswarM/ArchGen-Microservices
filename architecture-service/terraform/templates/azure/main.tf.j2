# Terraform Configuration generated by ArchGen AI
# Target Provider: Azure (azurerm)

{% set ns = namespace(has_subnets=false) %}
{% for node in nodes %}
  {% if node.type == 'SubnetGroupNode' %}
    {% set ns.has_subnets = true %}
  {% endif %}
{% endfor %}

{% macro get_subnet_id(node) -%}
  {%- if node.parentNode -%}
    {{- node.parentNode | sanitize_id -}}
  {%- else -%}
    {%- if node.type == 'GatewayNode' or node.type == 'FrontendNode' -%}
      {%- if ns.has_subnets -%}subnetingr{%- else -%}subnetingress{%- endif -%}
    {%- elif node.type == 'DatabaseNode' or node.type == 'CacheNode' -%}
      subnetdata
    {%- elif node.type == 'SecurityNode' or node.type == 'MonitoringNode' -%}
      subnetmgmt
    {%- else -%}
      subnetapp
    {%- endif -%}
  {%- endif -%}
{%- endmacro %}

terraform {
  required_version = ">= 1.3.0"
  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = "~> 3.0"
    }
    random = {
      source  = "hashicorp/random"
      version = "~> 3.5"
    }
  }
}

provider "azurerm" {
  features {}
}

# Unique suffix for strict Azure global naming
resource "random_string" "suffix" {
  length  = 6
  special = false
  upper   = false
}

# Core Resource Group for scoping deployment
resource "azurerm_resource_group" "rg" {
  name     = "rg-${var.project_name}-${var.environment}"
  location = var.location
}

# ==========================================
# SHARED INFRASTRUCTURE & NETWORKING
# ==========================================

resource "azurerm_virtual_network" "vnet" {
  name                = "vnet-${var.project_name}-${var.environment}"
  resource_group_name = azurerm_resource_group.rg.name
  location            = azurerm_resource_group.rg.location
  address_space       = ["{{ vnet_cidr }}"]
}

# Subnets mapped from the visual architecture canvas
{% if ns.has_subnets %}
{% for node in nodes %}
{% if node.type == 'SubnetGroupNode' %}
{% set safe_id = node.id | sanitize_id %}
resource "azurerm_subnet" "{{ safe_id }}" {
  name                 = "snet-{{ safe_id }}"
  resource_group_name  = azurerm_resource_group.rg.name
  virtual_network_name = azurerm_virtual_network.vnet.name
  address_prefixes     = ["{{ subnet_cidrs[node.id] }}"]
  
  # Delegate Data subnet for PostgreSQL Flexible Server if relevant
  {% if 'data' in node.id %}
  delegation {
    name = "fs-delegation"
    service_delegation {
      name    = "Microsoft.DBforPostgreSQL/flexibleServers"
      actions = ["Microsoft.Network/virtualNetworks/subnets/action"]
    }
  }
  {% endif %}
}
{% endif %}
{% endfor %}
{% else %}
resource "azurerm_subnet" "subnetingress" {
  name                 = "snet-ingress"
  resource_group_name  = azurerm_resource_group.rg.name
  virtual_network_name = azurerm_virtual_network.vnet.name
  address_prefixes     = ["{{ subnet_cidrs['subnet-ingress'] }}"]
}

resource "azurerm_subnet" "subnetapp" {
  name                 = "snet-app"
  resource_group_name  = azurerm_resource_group.rg.name
  virtual_network_name = azurerm_virtual_network.vnet.name
  address_prefixes     = ["{{ subnet_cidrs['subnet-app'] }}"]
}

resource "azurerm_subnet" "subnetdata" {
  name                 = "snet-data"
  resource_group_name  = azurerm_resource_group.rg.name
  virtual_network_name = azurerm_virtual_network.vnet.name
  address_prefixes     = ["{{ subnet_cidrs['subnet-data'] }}"]
  delegation {
    name = "fs-delegation"
    service_delegation {
      name    = "Microsoft.DBforPostgreSQL/flexibleServers"
      actions = ["Microsoft.Network/virtualNetworks/subnets/action"]
    }
  }
}

resource "azurerm_subnet" "subnetmgmt" {
  name                 = "snet-mgmt"
  resource_group_name  = azurerm_resource_group.rg.name
  virtual_network_name = azurerm_virtual_network.vnet.name
  address_prefixes     = ["{{ subnet_cidrs['subnet-mgmt'] }}"]
}

resource "azurerm_subnet" "subnetpe" {
  name                 = "snet-pe"
  resource_group_name  = azurerm_resource_group.rg.name
  virtual_network_name = azurerm_virtual_network.vnet.name
  address_prefixes     = ["{{ subnet_cidrs['subnet-pe'] }}"]
}
{% endif %}

# Network Security Groups
resource "azurerm_network_security_group" "nsg_ingress" {
  name                = "nsg-ingress"
  location            = azurerm_resource_group.rg.location
  resource_group_name = azurerm_resource_group.rg.name

  security_rule {
    name                       = "Allow_HTTP_HTTPS"
    priority                   = 100
    direction                  = "Inbound"
    access                     = "Allow"
    protocol                   = "Tcp"
    source_port_range          = "*"
    destination_port_ranges    = ["80", "443"]
    source_address_prefix      = "*"
    destination_address_prefix = "*"
  }
}

resource "azurerm_network_security_group" "nsg_app" {
  name                = "nsg-app"
  location            = azurerm_resource_group.rg.location
  resource_group_name = azurerm_resource_group.rg.name

  security_rule {
    name                       = "Allow_Ingress_Subnet"
    priority                   = 100
    direction                  = "Inbound"
    access                     = "Allow"
    protocol                   = "*"
    source_port_range          = "*"
    destination_port_range     = "*"
    source_address_prefix      = "{{ subnet_cidrs['subnet-ingress'] }}"
    destination_address_prefix = "*"
  }
}

resource "azurerm_network_security_group" "nsg_data" {
  name                = "nsg-data"
  location            = azurerm_resource_group.rg.location
  resource_group_name = azurerm_resource_group.rg.name

  security_rule {
    name                       = "Allow_App_Subnet"
    priority                   = 100
    direction                  = "Inbound"
    access                     = "Allow"
    protocol                   = "Tcp"
    source_port_range          = "*"
    destination_port_ranges    = ["5432", "6379"]
    source_address_prefix      = "{{ subnet_cidrs['subnet-app'] }}"
    destination_address_prefix = "*"
  }

  security_rule {
    name                       = "Deny_All_Ingress"
    priority                   = 200
    direction                  = "Inbound"
    access                     = "Deny"
    protocol                   = "*"
    source_port_range          = "*"
    destination_port_range     = "*"
    source_address_prefix      = "*"
    destination_address_prefix = "*"
  }
}

{% if ns.has_subnets %}
{% for node in nodes %}
{% if node.type == 'SubnetGroupNode' %}
{% set safe_id = node.id | sanitize_id %}
resource "azurerm_subnet_network_security_group_association" "assoc_{{ safe_id }}" {
  subnet_id                 = azurerm_subnet.{{ safe_id }}.id
  network_security_group_id = {% if 'ingress' in safe_id or 'gw' in safe_id %} azurerm_network_security_group.nsg_ingress.id
                              {% elif 'data' in safe_id or 'db' in safe_id %} azurerm_network_security_group.nsg_data.id
                              {% else %} azurerm_network_security_group.nsg_app.id
                              {% endif %}
}
{% endif %}
{% endfor %}
{% else %}
resource "azurerm_subnet_network_security_group_association" "assoc_ingress" {
  subnet_id                 = azurerm_subnet.subnetingress.id
  network_security_group_id = azurerm_network_security_group.nsg_ingress.id
}

resource "azurerm_subnet_network_security_group_association" "assoc_app" {
  subnet_id                 = azurerm_subnet.subnetapp.id
  network_security_group_id = azurerm_network_security_group.nsg_app.id
}

resource "azurerm_subnet_network_security_group_association" "assoc_data" {
  subnet_id                 = azurerm_subnet.subnetdata.id
  network_security_group_id = azurerm_network_security_group.nsg_data.id
}
{% endif %}

{% if has_backend %}
# Container App Environment for all Backend Microservices
resource "azurerm_container_app_environment" "app_env" {
  name                = "cae-${var.project_name}-${var.environment}"
  location            = azurerm_resource_group.rg.location
  resource_group_name = azurerm_resource_group.rg.name
}
{% endif %}

{% if has_database %}
# Shared Private DNS Zone for PostgreSQL Flexible Servers
resource "azurerm_private_dns_zone" "postgres_dns" {
  name                = "privatelink.postgres.database.azure.com"
  resource_group_name = azurerm_resource_group.rg.name
}

resource "azurerm_private_dns_zone_virtual_network_link" "postgres_dns_link" {
  name                  = "postgres-dns-link"
  resource_group_name   = azurerm_resource_group.rg.name
  private_dns_zone_name = azurerm_private_dns_zone.postgres_dns.name
  virtual_network_id    = azurerm_virtual_network.vnet.id
}
{% endif %}

{% for node in nodes %}
{% set safe_id = node.id | sanitize_id %}
{% set meta = (node.data.get('customMetadata') or {}) %}
# ==========================================
# SERVICE: {{ node.data.label }} ({{ node.type }})
# ==========================================
{% if node.type == 'GatewayNode' %}
# Network and IP Resources for Gateway Ingress
resource "azurerm_public_ip" "gw_pip_{{ safe_id }}" {
  name                = "pip-${substr(var.project_name, 0, 8)}-gw-${substr(var.environment, 0, 4)}-{{ safe_id }}"
  resource_group_name = azurerm_resource_group.rg.name
  location            = azurerm_resource_group.rg.location
  allocation_method   = "Static"
  sku                 = "Standard"
}

# Application Gateway Load Balancer
resource "azurerm_application_gateway" "app_gateway_{{ safe_id }}" {
  name                = "apgw-${substr(var.project_name, 0, 8)}-{{ safe_id }}"
  resource_group_name = azurerm_resource_group.rg.name
  location            = azurerm_resource_group.rg.location

  sku {
    name     = "{% if meta.get('pricingTier') == 'Basic' %}Standard_v2{% else %}WAF_v2{% endif %}"
    tier     = "{% if meta.get('pricingTier') == 'Basic' %}Standard_v2{% else %}WAF_v2{% endif %}"
    capacity = {% if meta.get('pricingTier') == 'Premium' %}4{% elif meta.get('pricingTier') == 'Basic' %}1{% else %}2{% endif %}
  }

  gateway_ip_configuration {
    name      = "my-gateway-ip-configuration"
    subnet_id = azurerm_subnet.{{ get_subnet_id(node) }}.id
  }

  frontend_port {
    name = "http_port"
    port = 80
  }

  frontend_ip_configuration {
    name                 = "my-frontend-ip-configuration"
    public_ip_address_id = azurerm_public_ip.gw_pip_{{ safe_id }}.id
  }

  backend_address_pool {
    name = "app_backend_pool"
  }

  backend_http_settings {
    name                  = "http_settings"
    cookie_based_affinity = "Disabled"
    port                  = 80
    protocol              = "Http"
    request_timeout       = 60
  }

  http_listener {
    name                           = "listener"
    frontend_ip_configuration_name = "my-frontend-ip-configuration"
    frontend_port_name             = "http_port"
    protocol                       = "Http"
  }

  request_routing_rule {
    name                       = "routing_rule"
    rule_type                  = "Basic"
    http_listener_name         = "listener"
    backend_address_pool_name  = "app_backend_pool"
    backend_http_settings_name = "http_settings"
    priority                   = 100
  }
}

{% elif node.type == 'FrontendNode' %}
# Static Web App for SPA hosting (React/Vue/Next.js)
resource "azurerm_static_web_app" "spa_frontend_{{ safe_id }}" {
  name                = "stt-${substr(var.project_name, 0, 8)}-fe-${substr(var.environment, 0, 4)}-{{ safe_id }}"
  resource_group_name = azurerm_resource_group.rg.name
  location            = "eastus2" # Azure Static Web Apps requires specific global hubs
}

{% elif node.type == 'BackendNode' %}
{% if node.id == 'aks-cluster' %}
# Azure Kubernetes Service (AKS) Managed Cluster
resource "azurerm_kubernetes_cluster" "aks_{{ safe_id }}" {
  name                = "aks-${substr(var.project_name, 0, 8)}-{{ safe_id }}"
  location            = azurerm_resource_group.rg.location
  resource_group_name = azurerm_resource_group.rg.name
  dns_prefix          = "aks-${var.project_name}"

  default_node_pool {
    name       = "systempool"
    node_count = {{ meta.get('minReplicas', '2') }}
    vm_size    = "{% if meta.get('pricingTier') == 'Premium' %}Standard_D4s_v5{% elif meta.get('pricingTier') == 'Basic' %}Standard_B2s{% else %}Standard_D2s_v5{% endif %}"
    vnet_subnet_id = azurerm_subnet.{{ get_subnet_id(node) }}.id
  }

  identity {
    type = "SystemAssigned"
  }
}
{% elif node.id == 'aks-system' %}
# System pool is defined inline within the default_node_pool of aks-cluster
{% elif node.id == 'aks-user' %}
# Additional AKS User Node Pool for workloads
resource "azurerm_kubernetes_cluster_node_pool" "user_pool_{{ safe_id }}" {
  name                  = "userpool"
  kubernetes_cluster_id = azurerm_kubernetes_cluster.aks_akscluster.id
  vm_size               = "{% if meta.get('pricingTier') == 'Premium' %}Standard_D8s_v5{% elif meta.get('pricingTier') == 'Basic' %}Standard_D2s_v5{% else %}Standard_D4s_v5{% endif %}"
  node_count            = {{ meta.get('maxReplicas', '3') }}
  vnet_subnet_id        = azurerm_subnet.{{ get_subnet_id(node) }}.id
}
{% else %}
# Container App Compute
resource "azurerm_container_app" "api_backend_{{ safe_id }}" {
  name                         = "ca-${substr(var.project_name, 0, 8)}-be-{{ safe_id }}"
  container_app_environment_id = azurerm_container_app_environment.app_env.id
  resource_group_name          = azurerm_resource_group.rg.name
  revision_mode                = "Single"

  template {
    min_replicas = {{ meta.get('minReplicas', '1') }}
    max_replicas = {{ meta.get('maxReplicas', '5') }}
    container {
      name   = "{{ safe_id }}"
      image  = "mcr.microsoft.com/azuredocs/aci-helloworld:latest"
      cpu    = "{% if meta.get('pricingTier') == 'Premium' %}1.0{% elif meta.get('pricingTier') == 'Basic' %}0.25{% else %}0.5{% endif %}"
      memory = "{% if meta.get('pricingTier') == 'Premium' %}2.0Gi{% elif meta.get('pricingTier') == 'Basic' %}0.5Gi{% else %}1.0Gi{% endif %}"
      
      env {
        name  = "ENVIRONMENT"
        value = var.environment
      }

      # Dynamic Environment Bindings based on visual edge connections!
      {% for edge in edges %}
      {% if edge.source == node.id and (edge.target.startswith('db') or 'db' in edge.target) %}
      env {
        name  = "DATABASE_URL"
        value = "postgresql://dbadmin:${var.db_password}@psql-${substr(var.project_name, 0, 8)}-db-${substr(var.environment, 0, 4)}-{{ edge.target | sanitize_id }}.postgres.database.azure.com/appdb"
      }
      {% endif %}
      {% if edge.source == node.id and (edge.target.startswith('redis') or 'cache' in edge.target) %}
      env {
        name  = "REDIS_HOST"
        value = "redis-${substr(var.project_name, 0, 8)}-cache-${substr(var.environment, 0, 4)}-{{ edge.target | sanitize_id }}.redis.cache.windows.net"
      }
      {% endif %}
      {% if edge.source == node.id and (edge.target.startswith('keyvault') or edge.target.startswith('kv') or 'vault' in edge.target) %}
      env {
        name  = "KEYVAULT_ENDPOINT"
        value = "https://kv-${substr(var.project_name, 0, 8)}-${substr(var.environment, 0, 4)}-{{ edge.target | sanitize_id }}.vault.azure.net/"
      }
      {% endif %}
      {% endfor %}
    }
  }

  ingress {
    external_enabled = true
    target_port      = 80
    traffic_weight {
      percentage      = 100
      latest_revision = true
    }
  }
}
{% endif %}

{% elif node.type == 'DatabaseNode' %}
{% if 'Cosmos' in node.data.label or 'nosql' in node.id %}
# Cosmos DB Account for NoSQL document storage
resource "azurerm_cosmosdb_account" "cosmos_db_{{ safe_id }}" {
  name                = "cosmos-${substr(var.project_name, 0, 8)}-db-${substr(var.environment, 0, 4)}-{{ safe_id }}"
  location            = azurerm_resource_group.rg.location
  resource_group_name = azurerm_resource_group.rg.name
  offer_type          = "Standard"
  kind                = "GlobalDocumentDB"

  consistency_policy {
    consistency_level = "Session"
  }

  geo_location {
    location          = azurerm_resource_group.rg.location
    failover_priority = 0
  }
}
{% else %}
# Flexible PostgreSQL Server for relational transactional security
resource "azurerm_postgresql_flexible_server" "postgres_db_{{ safe_id }}" {
  name                   = lower("psql-${substr(var.project_name, 0, 8)}-db-${substr(var.environment, 0, 4)}-{{ safe_id }}")
  resource_group_name    = azurerm_resource_group.rg.name
  location               = azurerm_resource_group.rg.location
  version                = "14"
  administrator_login    = "dbadmin"
  administrator_password = var.db_password
  sku_name               = "{% if meta.get('pricingTier') == 'Premium' %}GP_Standard_D4ds_v4{% elif meta.get('pricingTier') == 'Basic' %}B_Standard_s1{% else %}GP_Standard_D2ds_v4{% endif %}"
  storage_mb             = {% if meta.get('pricingTier') == 'Premium' %}131072{% else %}32768{% endif %}
  backup_retention_days  = 7
  delegated_subnet_id    = azurerm_subnet.{{ get_subnet_id(node) }}.id
  private_dns_zone_id    = azurerm_private_dns_zone.postgres_dns.id
  
  depends_on = [azurerm_private_dns_zone_virtual_network_link.postgres_dns_link]
}

resource "azurerm_postgresql_flexible_server_database" "main_db_{{ safe_id }}" {
  name      = "appdb"
  server_id = azurerm_postgresql_flexible_server.postgres_db_{{ safe_id }}.id
  collation = "en_US.utf8"
  charset   = "utf8"
}
{% endif %}

{% elif node.type == 'CacheNode' %}
# Redis Cache for quick session states and transient database caching
resource "azurerm_redis_cache" "redis_cache_{{ safe_id }}" {
  name                = "redis-${substr(var.project_name, 0, 8)}-cache-${substr(var.environment, 0, 4)}-{{ safe_id }}"
  location            = azurerm_resource_group.rg.location
  resource_group_name = azurerm_resource_group.rg.name
  capacity            = {% if meta.get('pricingTier') == 'Premium' %}2{% elif meta.get('pricingTier') == 'Basic' %}0{% else %}1{% endif %}
  family              = "{% if meta.get('pricingTier') == 'Premium' %}P{% else %}C{% endif %}"
  sku_name            = "{% if meta.get('pricingTier') == 'Premium' %}Premium{% elif meta.get('pricingTier') == 'Basic' %}Basic{% else %}Standard{% endif %}"
  non_ssl_port_enabled = false
  minimum_tls_version = "1.2"
}

{% elif node.type == 'StorageNode' %}
# General Purpose Block Storage for documents and binary files
resource "azurerm_storage_account" "blob_storage_{{ safe_id }}" {
  name                     = lower("st${substr(var.project_name, 0, 6)}${substr(var.environment, 0, 3)}${random_string.suffix.result}{{ safe_id }}")
  resource_group_name      = azurerm_resource_group.rg.name
  location                 = azurerm_resource_group.rg.location
  account_tier             = "Standard"
  account_replication_type = "LRS"
}

resource "azurerm_storage_container" "upload_bucket_{{ safe_id }}" {
  name                  = "media"
  storage_account_name  = azurerm_storage_account.blob_storage_{{ safe_id }}.name
  container_access_type = "blob"
}

{% elif node.type == 'SecurityNode' %}
{% if node.id.startswith('pe-') %}
# Private Endpoint for secure internal connection
resource "azurerm_private_endpoint" "pe_{{ safe_id }}" {
  name                = "pe-{{ safe_id }}"
  location            = azurerm_resource_group.rg.location
  resource_group_name = azurerm_resource_group.rg.name
  subnet_id           = azurerm_subnet.{{ get_subnet_id(node) }}.id

  private_service_connection {
    name                           = "psc-{{ safe_id }}"
    private_connection_resource_id = {% if 'db' in node.id %} azurerm_postgresql_flexible_server.postgres_db_dbprimary.id
                                     {% elif 'kv' in node.id %} azurerm_key_vault.key_vault_keyvault.id
                                     {% elif 'storage' in node.id %} azurerm_storage_account.blob_storage_blob.id
                                     {% else %} azurerm_key_vault.key_vault_keyvault.id
                                     {% endif %}
    subresource_names              = [{% if 'db' in node.id %} "postgresqlServer"
                                     {% elif 'kv' in node.id %} "vault"
                                     {% elif 'storage' in node.id %} "blob"
                                     {% else %} "vault"
                                     {% endif %}]
    is_manual_connection           = false
  }
}
{% elif 'ddos' in node.id %}
# DDoS Protection Plan for volumetric attack mitigation
resource "azurerm_network_ddos_protection_plan" "ddos_{{ safe_id }}" {
  name                = "ddos-${substr(var.project_name, 0, 8)}-${substr(var.environment, 0, 4)}-{{ safe_id }}"
  location            = azurerm_resource_group.rg.location
  resource_group_name = azurerm_resource_group.rg.name
}
{% else %}
# Key Vault for system secret generation and certificate storage
resource "azurerm_key_vault" "key_vault_{{ safe_id }}" {
  name                        = "kv-${substr(var.project_name, 0, 6)}-${substr(var.environment, 0, 3)}-{{ safe_id }}"
  location                    = azurerm_resource_group.rg.location
  resource_group_name         = azurerm_resource_group.rg.name
  enabled_for_disk_encryption = true
  tenant_id                   = "00000000-0000-0000-0000-000000000000" # Placeholder UUID for configuration
  sku_name                    = "standard"
}
{% endif %}
{% endif %}

{% endfor %}
